# Copy this file to .env before running the stack.
# All values shown here are the defaults used when .env is absent.

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Exposed host ports (change if something is already using these)
APP_PORT=3000
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
LOKI_PORT=3100
